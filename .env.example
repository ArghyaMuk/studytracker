# StudyPilot Environment Configuration
# Copy this to .env and fill in your values

# Database
DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/studypilot_users

# Redis
REDIS_URL=redis://localhost:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# JWT
JWT_SECRET_KEY=change-me-to-a-strong-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Gemini API (for Quiz Generation)
GEMINI_API_KEY=your-gemini-api-key-here

# OpenRouter API (fallback when Gemini quota exceeded)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Service URLs (for inter-service communication)
USER_SERVICE_URL=http://localhost:8001
CURRICULUM_SERVICE_URL=http://localhost:8002
SESSION_SERVICE_URL=http://localhost:8003
REPETITION_SERVICE_URL=http://localhost:8004
QUIZ_SERVICE_URL=http://localhost:8005
READINESS_SERVICE_URL=http://localhost:8006
NOTIFICATION_SERVICE_URL=http://localhost:8007
